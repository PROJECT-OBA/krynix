{
  "name": "@krynix/core",
  "version": "0.1.1",
  "publishConfig": {
    "access": "public"
  },
  "description": "Core primitives for Krynix: trace events, hash chains, sessions, canonical JSON, and schema validation",
  "author": "PROJECT-OBA",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/PROJECT-OBA/krynix.git",
    "directory": "packages/core"
  },
  "keywords": ["krynix", "trace", "hash-chain", "ai-agent", "trust", "observability"],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "schemas",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "generate:schemas": "tsx scripts/generate-schemas.ts"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  }
}
