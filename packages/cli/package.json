{
  "name": "@krynix/cli",
  "version": "0.1.1",
  "publishConfig": {
    "access": "public"
  },
  "description": "Command-line interface for Krynix: policy evaluation, trace verification, replay, and compliance reporting",
  "author": "PROJECT-OBA",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/PROJECT-OBA/krynix.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/PROJECT-OBA/krynix#readme",
  "bugs": "https://github.com/PROJECT-OBA/krynix/issues",
  "keywords": ["krynix", "cli", "policy", "trace", "ai-agent", "trust"],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "krynix": "./dist/main.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@krynix/core": "workspace:*",
    "@krynix/policy": "workspace:*",
    "@krynix/replay": "workspace:*"
  }
}
