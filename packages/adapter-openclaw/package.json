{
  "name": "@krynix/adapter-openclaw",
  "version": "0.1.1",
  "publishConfig": {
    "access": "public"
  },
  "description": "OpenClaw adapter for Krynix: translates OpenClaw plugin hook events into Krynix trace events",
  "author": "PROJECT-OBA",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/PROJECT-OBA/krynix.git",
    "directory": "packages/adapter-openclaw"
  },
  "homepage": "https://github.com/PROJECT-OBA/krynix/tree/main/packages/adapter-openclaw#readme",
  "bugs": "https://github.com/PROJECT-OBA/krynix/issues",
  "keywords": ["krynix", "openclaw", "adapter", "ai-agent", "trace", "observability"],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@krynix/core": "workspace:*"
  },
  "devDependencies": {
    "@krynix/policy": "workspace:*",
    "@krynix/replay": "workspace:*"
  }
}
