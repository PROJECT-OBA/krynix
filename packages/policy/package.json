{
  "name": "@krynix/policy",
  "version": "0.2.2",
  "publishConfig": {
    "access": "public"
  },
  "description": "Policy evaluation engine for Krynix: YAML policy parsing, rule matching, and trace evaluation",
  "author": "PROJECT-OBA",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/PROJECT-OBA/krynix.git",
    "directory": "packages/policy"
  },
  "homepage": "https://github.com/PROJECT-OBA/krynix/tree/main/packages/policy#readme",
  "bugs": "https://github.com/PROJECT-OBA/krynix/issues",
  "keywords": [
    "krynix",
    "policy",
    "evaluation",
    "ai-agent",
    "trust",
    "compliance"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@krynix/core": "workspace:*",
    "yaml": "^2.8.3"
  }
}
