{
  "name": "@krynix/adapter-langchain",
  "version": "0.1.1",
  "publishConfig": {
    "access": "public"
  },
  "description": "LangChain adapter for Krynix: translates LangChain callback events into Krynix trace events",
  "author": "PROJECT-OBA",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/PROJECT-OBA/krynix.git",
    "directory": "packages/adapter-langchain"
  },
  "keywords": ["krynix", "langchain", "adapter", "ai-agent", "trace", "observability"],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@krynix/core": "workspace:*"
  },
  "devDependencies": {
    "@krynix/policy": "workspace:*",
    "@langchain/core": "^1.1.39"
  }
}
