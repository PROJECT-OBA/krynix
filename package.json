{
  "name": "krynix",
  "version": "0.1.1",
  "private": true,
  "description": "Policy gates for AI agent behavior — trace, evaluate, and enforce agent actions",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/PROJECT-OBA/krynix.git"
  },
  "homepage": "https://github.com/PROJECT-OBA/krynix#readme",
  "bugs": "https://github.com/PROJECT-OBA/krynix/issues",
  "type": "module",
  "engines": {
    "node": ">=20",
    "pnpm": ">=8"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:golden": "vitest run test/integration/golden-traces.test.ts",
    "test:integration": "vitest run test/integration/",
    "test:e2e": "vitest run test/integration/cli-binary.test.ts test/integration/e2e-scenarios.test.ts test/integration/compliance-roundtrip.test.ts test/integration/openclaw-live.test.ts",
    "test:all": "vitest run",
    "typecheck": "tsc -b",
    "lint": "eslint 'packages/*/src/**/*.ts'",
    "lint:fix": "eslint 'packages/*/src/**/*.ts' --fix",
    "format": "prettier --write 'packages/*/src/**/*.ts'",
    "format:check": "prettier --check 'packages/*/src/**/*.ts'",
    "docs:check": "pnpm docs:check:links && pnpm docs:check:terminology && pnpm docs:check:claims && pnpm docs:check:readme",
    "docs:check:links": "node scripts/docs/check-links.mjs",
    "docs:check:terminology": "node scripts/docs/check-terminology.mjs",
    "docs:check:claims": "node scripts/docs/check-claim-tags.mjs",
    "docs:check:readme": "node scripts/docs/check-readme-consistency.mjs",
    "clean": "pnpm -r clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "eslint": "^9.20.0",
    "eslint-config-prettier": "^10.0.1",
    "prettier": "^3.5.0",
    "tsup": "^8.4.0",
    "tsx": "^4.8.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.24.0",
    "vitest": "^3.0.0"
  }
}
